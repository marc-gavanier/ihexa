{
  "name": "ihexa",
  "version": "1.0.0",
  "description": "",
  "type": "module",
  "browserslist": ["> 1%", "maintained node versions", "not dead"],
  "main": "index.js",
  "scripts": {
    "generate:implementations": "./scripts/generate-implementations.sh",
    "predev": "pnpm generate:implementations && pnpm i18n:interface",
    "prebuild": "pnpm generate:implementations && pnpm i18n:interface",
    "dev": "next dev",
    "dev@prod": "ENV=prod pnpm dev",
    "build": "next build",
    "postbuild": "next-sitemap",
    "start": "next start",
    "test": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:cucumber": "pnpm generate:implementations && NODE_OPTIONS='--import tsx/esm --import dotenv/config' cucumber-js 'src/features/**/*.feature' --import 'src/features/**/*.steps.ts'",
    "test:cucumber@prod": "pnpm generate:implementations && ENV=prod pnpm test:cucumber",
    "test:e2e": "playwright test",
    "lint:code:fix": "pnpm exec biome check --write",
    "lint:code:ci": "pnpm exec biome ci",
    "lint:commit": "commitlint --from origin/main",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:check": "drizzle-kit check",
    "db:studio": "drizzle-kit studio",
    "lint:architecture": "depcruise src && folderslint",
    "doc:architecture": "depcruise src --include-only \"^src\" --output-type dot | dot -T svg > dependency-graph.svg",
    "storybook:dev": "storybook dev -p 6006",
    "storybook:build": "storybook build",
    "bundle:analyze": "source-map-explorer '.next/static/**/*.js'",
    "i18n:interface": "i18next-resources-for-ts interface -i public/locales/en-US -o @types/resources.d.ts",
    "prepare": "husky",
    "postinstall": "pnpm i18n:interface"
  },
  "keywords": ["ihexa", "training", "feature-based", "clean-architecture", "react", "nextjs", "typescript"],
  "contributors": [
    {
      "name": "Marc Gavanier",
      "email": "marc.gavanier@gmail.com",
      "url": "https://www.linkedin.com/in/marc-gavanier/"
    }
  ],
  "license": "MIT",
  "devDependencies": {
    "@biomejs/biome": "^2.4.7",
    "@chromatic-com/storybook": "^5.0.1",
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@csstools/postcss-cascade-layers": "^6.0.0",
    "@cucumber/cucumber": "^12.7.0",
    "@estruyf/github-actions-reporter": "^1.11.0",
    "@playwright/test": "^1.58.2",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^12.0.6",
    "@storybook/addon-a11y": "^10.2.19",
    "@storybook/addon-docs": "^10.2.19",
    "@storybook/addon-mcp": "^0.5.0",
    "@storybook/addon-onboarding": "^10.2.19",
    "@storybook/addon-styling-webpack": "^3.0.0",
    "@storybook/addon-vitest": "^10.2.19",
    "@storybook/nextjs-vite": "^10.2.19",
    "@types/node": "^25.5.0",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.2.0",
    "@vitest/browser": "4.1.0",
    "@vitest/browser-playwright": "4.1.0",
    "@vitest/coverage-v8": "4.1.0",
    "dependency-cruiser": "^17.3.9",
    "drizzle-kit": "^0.31.10",
    "folderslint": "^1.2.0",
    "husky": "^9.1.7",
    "i18next-resources-for-ts": "^2.0.2",
    "lint-staged": "^16.4.0",
    "next-sitemap": "^4.2.3",
    "pino-pretty": "^13.1.3",
    "playwright": "^1.58.2",
    "postcss": "^8.5.8",
    "semantic-release": "^25.0.3",
    "source-map-explorer": "^2.5.3",
    "sst": "^4.3.6",
    "storybook": "^10.2.19",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vitest": "^4.1.0"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@sentry/nextjs": "^10.46.0",
    "@socialgouv/matomo-next": "^1.13.1",
    "@tailwindcss/postcss": "^4.2.1",
    "@tailwindcss/typography": "^0.5.19",
    "@tanstack/react-form": "^1.28.5",
    "clsx": "^2.1.1",
    "daisyui": "^5.5.19",
    "dotenv": "^17.3.1",
    "downshift": "^9.3.2",
    "drizzle-orm": "^0.45.2",
    "effect": "^3.20.0",
    "i18next": "^25.8.18",
    "motion": "^12.38.0",
    "next": "^16.2.1",
    "next-themes": "^0.4.6",
    "pg": "^8.20.0",
    "pino": "^10.3.1",
    "piqure": "^2.1.2",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-hot-toast": "^2.6.0",
    "react-i18next": "^16.5.8",
    "react-icons": "^5.6.0",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.1",
    "tailwindcss-animate": "^1.0.7"
  }
}
