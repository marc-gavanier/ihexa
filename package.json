{
  "name": "ihexa",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "test": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:cucumber": "NODE_OPTIONS='--import tsx/esm' cucumber-js src/features/**/*.feature --import src/features/**/*.feature.ts",
    "test:e2e": "playwright test",
    "lint:check": "biome check --write",
    "lint:ci": "biome ci",
    "lint:commit": "commitlint --from origin/main",
    "lint:architecture": "depcruise src && folderslint",
    "resolve:profile": "tsx src/scripts/resolve-profile.ts",
    "generate:paths": "tsx src/scripts/generate-tsconfig-paths.ts",
    "doc:architecture": "depcruise src --include-only \"^src\" --output-type dot | dot -T svg > dependency-graph.svg",
    "storybook:dev": "storybook dev -p 6006",
    "storybook:build": "storybook build",
    "next:analyze": "next experimental-analyze",
    "email:dev": "email dev",
    "i18n:interface": "i18next-resources-for-ts interface -i public/locales/en -o @types/resources.d.ts",
    "prepare": "husky",
    "postinstall": "pnpm i18n:interface",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build"
  },
  "keywords": [],
  "author": "",
  "license": "MIT",
  "packageManager": "pnpm@10.15.1",
  "devDependencies": {
    "@biomejs/biome": "^2.4.7",
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "dependency-cruiser": "^17.3.9",
    "folderslint": "^1.2.0",
    "lint-staged": "^16.4.0",
    "typescript": "^5.9.2"
  },
  "dependencies": {
    "next": "^16.1.7"
  }
}
